# ==========================================
# VECTOR DATABASE (Required for both)
# ==========================================
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX_NAME=RateMyProfAISummarizer
PINECONE_ENVIRONMENT=gcp-starter

# ==========================================
# MODEL CONFIGURATION
# ==========================================
# Set to 'local' for Ollama or 'cloud' for Web Deployment
MODEL_TYPE=local

# Only needed if MODEL_TYPE is 'cloud'
# (e.g., Groq for free cloud Llama 3 or OpenAI)
CLOUD_API_KEY=your_api_key_here
CLOUD_BASE_URL=https://api.groq.com/openai/v1 

# ==========================================
# EMBEDDING CONFIGURATION
# ==========================================
# We use 'all-MiniLM-L6-v2' (Free & Local)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2